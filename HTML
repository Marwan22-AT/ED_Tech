<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ed-Tech - منصة الكورسات</title>
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <!-- Login Screen -->
    <div id="login-screen" class="login-screen">
        <div class="login-container">
            <div class="login-logo">
                <i class="fas fa-graduation-cap"></i>
                <h1>Ed-Tech</h1>
                <p data-ar="منصة التعلم الاحترافية" data-en="Professional Learning Platform">منصة التعلم الاحترافية</p>
            </div>
            
            <form id="login-form" class="login-form">
                <div class="form-group">
                    <label data-ar="البريد الإلكتروني" data-en="Email">البريد الإلكتروني</label>
                    <input type="email" id="login-email" required placeholder="example@email.com">
                </div>
                
                <div class="form-group">
                    <label data-ar="كلمة المرور" data-en="Password">كلمة المرور</label>
                    <input type="password" id="login-password" required placeholder="••••••••">
                    <i class="fas fa-eye toggle-password" onclick="togglePassword()"></i>
                </div>
                
                <div class="form-options">
                    <label class="remember-me">
                        <input type="checkbox">
                        <span data-ar="تذكرني" data-en="Remember me">تذكرني</span>
                    </label>
                    <a href="#" class="forgot-password" data-ar="نسيت كلمة المرور؟" data-en="Forgot password?">نسيت كلمة المرور؟</a>
                </div>
                
                <button type="submit" class="btn-login" data-ar="تسجيل الدخول" data-en="Login">
                    <span>تسجيل الدخول</span>
                    <i class="fas fa-arrow-left"></i>
                </button>
            </form>
            
            <div class="login-divider">
                <span data-ar="أو" data-en="OR">أو</span>
            </div>
            
            <div class="social-login">
                <button class="btn-social btn-google">
                    <i class="fab fa-google"></i>
                    <span>Google</span>
                </button>
                <button class="btn-social btn-facebook">
                    <i class="fab fa-facebook-f"></i>
                    <span>Facebook</span>
                </button>
            </div>
            
            <p class="signup-link">
                <span data-ar="ليس لديك حساب؟" data-en="Don't have an account?">ليس لديك حساب؟</span>
                <a href="#" data-ar="سجل الآن" data-en="Sign up now">سجل الآن</a>
            </p>
        </div>
        
        <div class="login-bg">
            <div class="floating-shapes">
                <div class="shape"></div>
                <div class="shape"></div>
                <div class="shape"></div>
                <div class="shape"></div>
            </div>
        </div>
    </div>

    <!-- Main App (Hidden initially) -->
    <div id="main-app" class="main-app hidden">
        
        <!-- Navigation -->
        <nav class="navbar">
            <div class="nav-container">
                <div class="logo">
                    <i class="fas fa-graduation-cap"></i>
                    <span>Ed-Tech</span>
                </div>
                
                <ul class="nav-links">
                    <li><a href="#home" class="active" data-ar="الرئيسية" data-en="Home">الرئيسية</a></li>
                    <li><a href="#courses" data-ar="الكورسات" data-en="Courses">الكورسات</a></li>
                    <li><a href="#about" data-ar="عنّا" data-en="About">عنّا</a></li>
                    <li><a href="#contact" data-ar="تواصل معنا" data-en="Contact">تواصل معنا</a></li>
                </ul>
                
                <div class="nav-actions">
                    <button class="lang-switch" onclick="toggleLanguage()">
                        <i class="fas fa-globe"></i>
                        <span id="current-lang">EN</span>
                    </button>
                    
                    <div class="user-menu">
                        <img src="https://ui-avatars.com/api/?name=User&background=6366f1&color=fff" alt="User">
                        <span id="user-name">User</span>
                        <button onclick="logout()" class="btn-logout" title="Logout">
                            <i class="fas fa-sign-out-alt"></i>
                        </button>
                    </div>
                </div>
                
                <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
        </nav>

        <!-- Hero Section -->
        <section id="home" class="hero">
            <div class="hero-content">
                <h1 data-ar="طوّر مهاراتك مع أفضل الكورسات" data-en="Develop Your Skills with Best Courses">
                    طوّر مهاراتك مع أفضل الكورسات
                </h1>
                <p data-ar="تعلم من الخبراء في مجالات التسويق الرقمي، تطوير الألعاب، التصميم، والمزيد" 
                   data-en="Learn from experts in Digital Marketing, Game Development, Design, and more">
                    تعلم من الخبراء في مجالات التسويق الرقمي، تطوير الألعاب، التصميم، والمزيد
                </p>
                <div class="hero-buttons">
                    <a href="#courses" class="btn-primary" data-ar="استكشف الكورسات" data-en="Explore Courses">
                        استكشف الكورسات
                    </a>
                    <a href="#free-courses" class="btn-secondary" data-ar="كورسات مجانية" data-en="Free Courses">
                        كورسات مجانية
                    </a>
                </div>
                
                <div class="hero-stats">
                    <div class="stat">
                        <span class="stat-number">50+</span>
                        <span class="stat-label" data-ar="كورس" data-en="Courses">كورس</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">10K+</span>
                        <span class="stat-label" data-ar="طالب" data-en="Students">طالب</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">4.9</span>
                        <span class="stat-label" data-ar="تقييم" data-en="Rating">تقييم</span>
                    </div>
                </div>
            </div>
            
            <div class="hero-image">
                <div class="hero-card card-1">
                    <i class="fas fa-chart-line"></i>
                    <span data-ar="تسويق رقمي" data-en="Digital Marketing">تسويق رقمي</span>
                </div>
                <div class="hero-card card-2">
                    <i class="fas fa-gamepad"></i>
                    <span data-ar="تطوير ألعاب" data-en="Game Dev">تطوير ألعاب</span>
                </div>
                <div class="hero-card card-3">
                    <i class="fas fa-palette"></i>
                    <span data-ar="تصميم" data-en="Design">تصميم</span>
                </div>
            </div>
        </section>

        <!-- Courses Section -->
        <section id="courses" class="courses-section">
            <div class="container">
                <div class="section-header">
                    <h2 data-ar="كورساتنا" data-en="Our Courses">كورساتنا</h2>
                    <p data-ar="اختر مسارك التعليمي وابدأ رحلتك نحو الاحتراف" 
                       data-en="Choose your learning path and start your journey to mastery">
                        اختر مسارك التعليمي وابدأ رحلتك نحو الاحتراف
                    </p>
                </div>
                
                <!-- Filter Buttons -->
                <div class="course-filters">
                    <button class="filter-btn active" data-filter="all" 
                            data-ar="الكل" data-en="All">الكل</button>
                    <button class="filter-btn" data-filter="free" 
                            data-ar="مجاني" data-en="Free">مجاني</button>
                    <button class="filter-btn" data-filter="paid" 
                            data-ar="مدفوع" data-en="Paid">مدفوع</button>
                </div>
                
                <!-- Courses Grid -->
                <div class="courses-grid" id="courses-grid">
                    <!-- Courses will be inserted here by JavaScript -->
                </div>
            </div>
        </section>

        <!-- Free Courses Highlight -->
        <section id="free-courses" class="free-section">
            <div class="container">
                <div class="free-banner">
                    <div class="free-content">
                        <span class="free-badge" data-ar="مجاناً" data-en="FREE">مجاناً</span>
                        <h2 data-ar="ابدأ رحلتك التعليمية مجاناً" data-en="Start Your Learning Journey for Free">
                            ابدأ رحلتك التعليمية مجاناً
                        </h2>
                        <p data-ar="اكتشف كورساتنا المجانية وابنِ أساساً قوياً في مجالك المفضل" 
                           data-en="Discover our free courses and build a strong foundation in your favorite field">
                            اكتشف كورساتنا المجانية وابنِ أساساً قوياً في مجالك المفضل
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- About Section -->
        <section id="about" class="about-section">
            <div class="container">
                <div class="about-grid">
                    <div class="about-content">
                        <h2 data-ar="لماذا تختار Ed-Tech؟" data-en="Why Choose Ed-Tech?">
                            لماذا تختار Ed-Tech؟
                        </h2>
                        <div class="features-list">
                            <div class="feature">
                                <i class="fas fa-certificate"></i>
                                <div>
                                    <h3 data-ar="شهادات معتمدة" data-en="Certified Certificates">شهادات معتمدة</h3>
                                    <p data-ar="احصل على شهادة معتمدة بعد إتمام كل كورس" 
                                       data-en="Get a certified certificate upon completing each course">احصل على شهادة معتمدة بعد إتمام كل كورس</p>
                                </div>
                            </div>
                            <div class="feature">
                                <i class="fas fa-infinity"></i>
                                <div>
                                    <h3 data-ar="وصول مدى الحياة" data-en="Lifetime Access">وصول مدى الحياة</h3>
                                    <p data-ar="تعلم في أي وقت ومن أي مكان بدون قيود" 
                                       data-en="Learn anytime, anywhere without restrictions">تعلم في أي وقت ومن أي مكان بدون قيود</p>
                                </div>
                            </div>
                            <div class="feature">
                                <i class="fas fa-users"></i>
                                <div>
                                    <h3 data-ar="مدربون خبراء" data-en="Expert Instructors">مدربون خبراء</h3>
                                    <p data-ar="تعلم من أفضل الخبراء في كل مجال" 
                                       data-en="Learn from the best experts in every field">تعلم من أفضل الخبراء في كل مجال</p>
                                </div>
                            </div>
                            <div class="feature">
                                <i class="fas fa-headset"></i>
                                <div>
                                    <h3 data-ar="دعم فني 24/7" data-en="24/7 Support">دعم فني 24/7</h3>
                                    <p data-ar="فريق دعم جاهز لمساعدتك في أي وقت" 
                                       data-en="Support team ready to help you anytime">فريق دعم جاهز لمساعدتك في أي وقت</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="about-image">
                        <div class="about-card">
                            <i class="fas fa-trophy"></i>
                            <span data-ar="أفضل منصة تعليمية 2024" data-en="Best EdTech Platform 2024">أفضل منصة تعليمية 2024</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <section id="contact" class="contact-section">
            <div class="container">
                <div class="section-header">
                    <h2 data-ar="تواصل معنا" data-en="Contact Us">تواصل معنا</h2>
                </div>
                <div class="contact-grid">
                    <div class="contact-info">
                        <div class="contact-item">
                            <i class="fas fa-envelope"></i>
                            <span>info@ed-tech.com</span>
                        </div>
                        <div class="contact-item">
                            <i class="fas fa-phone"></i>
                            <span>+20 123 456 7890</span>
                        </div>
                        <div class="contact-item">
                            <i class="fas fa-map-marker-alt"></i>
                            <span data-ar="القاهرة، مصر" data-en="Cairo, Egypt">القاهرة، مصر</span>
                        </div>
                    </div>
                    <form class="contact-form">
                        <input type="text" placeholder="الاسم / Name" required>
                        <input type="email" placeholder="البريد الإلكتروني / Email" required>
                        <textarea placeholder="رسالتك / Your Message" rows="5" required></textarea>
                        <button type="submit" class="btn-primary" data-ar="إرسال" data-en="Send">إرسال</button>
                    </form>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="footer">
            <div class="container">
                <div class="footer-grid">
                    <div class="footer-brand">
                        <div class="logo">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Ed-Tech</span>
                        </div>
                        <p data-ar="منصتك الأولى للتعلم الاحترافي والتطوير المستمر" 
                           data-en="Your first platform for professional learning and continuous development">
                            منصتك الأولى للتعلم الاحترافي والتطوير المستمر
                        </p>
                    </div>
                    <div class="footer-links">
                        <h4 data-ar="روابط سريعة" data-en="Quick Links">روابط سريعة</h4>
                        <ul>
                            <li><a href="#home" data-ar="الرئيسية" data-en="Home">الرئيسية</a></li>
                            <li><a href="#courses" data-ar="الكورسات" data-en="Courses">الكورسات</a></li>
                            <li><a href="#about" data-ar="عنّا" data-en="About">عنّا</a></li>
                        </ul>
                    </div>
                    <div class="footer-social">
                        <h4 data-ar="تابعنا" data-en="Follow Us">تابعنا</h4>
                        <div class="social-icons">
                            <a href="#"><i class="fab fa-facebook"></i></a>
                            <a href="#"><i class="fab fa-twitter"></i></a>
                            <a href="#"><i class="fab fa-instagram"></i></a>
                            <a href="#"><i class="fab fa-linkedin"></i></a>
                            <a href="#"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p>© 2024 Ed-Tech. <span data-ar="جميع الحقوق محفوظة" data-en="All rights reserved">جميع الحقوق محفوظة</span></p>
                </div>
            </div>
        </footer>
    </div>

    <script src="js/app.js"></script>
</body>
</html>
